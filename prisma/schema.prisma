datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  alias        String  @unique @db.VarChar(50)
  name         String  @db.VarChar(100)
  lastName     String  @map("last_name") @db.VarChar(100)
  email        String  @unique @db.VarChar(100)
  passwordHash String  @map("password_hash") @db.VarChar(255)

  salesLogged         Sale[]       @relation("SaleLogger")
  salesCollected      Sale[]       @relation("SaleCollector")
  expensesLogged      Expense[]    @relation("ExpenseLogger")
  expensesPaid        Expense[]    @relation("ExpensePayer")
  conversionsLogged   Conversion[] @relation("ConversionLogger")
  conversionsSent     Conversion[] @relation("ConversionSender")
  conversionsReceived Conversion[] @relation("ConversionReceiver")
  batchSupplierPayments BatchSupplierPayment[] @relation("BatchSupplierPaymentUser")
  batchesShippingPaid   Batch[]                 @relation("BatchShippingPayer")
  shipmentsPaid       Shipment[]   @relation("ShipmentShippingPayer")
  adjustments         Adjustment[] @relation("AdjustmentUser")
  adjustmentsLogged   Adjustment[] @relation("AdjustmentLogger")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("users")
}

model Batch {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  purchaseDate     DateTime @default(now()) @map("purchase_date") @db.Date
  arrivalDate      DateTime? @map("arrival_date") @db.Date
  quantity         Int
  trackingNumber   String?  @map("tracking_number") @db.VarChar(100)
  description      String?  @db.Text
  shippingPriceUsd Decimal? @map("shipping_price_usd") @db.Decimal(10, 2)
  shippingPriceUyu Decimal? @map("shipping_price_uyu") @db.Decimal(10, 2)
  weight           Decimal? @db.Decimal(10, 2)
  supplier         String?  @db.VarChar(200)

  shippingPaidByUserId String? @map("shipping_paid_by_user_id") @db.Uuid
  shippingPaidByUser   User?   @relation("BatchShippingPayer", fields: [shippingPaidByUserId], references: [id])

  supplierPayments BatchSupplierPayment[]

  items     InventoryItem[]
  shipments Shipment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("batches")
}

model BatchSupplierPayment {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  batchId   String  @map("batch_id") @db.Uuid
  userId    String  @map("user_id") @db.Uuid
  amountUsd Decimal @map("amount_usd") @db.Decimal(10, 2)

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  user  User  @relation("BatchSupplierPaymentUser", fields: [userId], references: [id])

  @@unique([batchId, userId])
  @@index([batchId])
  @@map("batch_supplier_payments")
}

model Shipment {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  batchId          String   @map("batch_id") @db.Uuid
  date             DateTime @db.Date
  trackingNumber   String?  @map("tracking_number") @db.VarChar(100)
  shippingPriceUsd Decimal? @map("shipping_price_usd") @db.Decimal(10, 2)
  shippingPriceUyu Decimal? @map("shipping_price_uyu") @db.Decimal(10, 2)
  weight           Decimal? @db.Decimal(10, 2)

  shippingPaidByUserId String? @map("shipping_paid_by_user_id") @db.Uuid
  shippingPaidByUser   User?   @relation("ShipmentShippingPayer", fields: [shippingPaidByUserId], references: [id])

  batch Batch           @relation(fields: [batchId], references: [id], onDelete: Cascade)
  items InventoryItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([batchId])
  @@map("shipments")
}

model Team {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String           @unique @db.VarChar(100)
  products  CatalogProduct[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("teams")
}

model CatalogProduct {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teamId      String  @map("team_id") @db.Uuid
  team        Team    @relation(fields: [teamId], references: [id])
  season      String  @db.VarChar(20)
  version     String? @db.VarChar(50)
  color       String  @db.VarChar(50)
  number      Int?
  player      String? @db.VarChar(100)
  description String? @db.Text
  type        String? @db.VarChar(20)
  sleeve      String? @db.VarChar(10)
  photos      Json    @default("[]")
  items       InventoryItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([teamId, season, version, color, number, sleeve, type])
  @@map("catalog_products")
}

model InventoryItem {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  catalogProductId String   @map("catalog_product_id") @db.Uuid
  batchId          String   @map("batch_id") @db.Uuid
  shipmentId       String?  @map("shipment_id") @db.Uuid
  size             String   @db.VarChar(10)
  basePriceUsd     Decimal  @map("base_price_usd") @db.Decimal(10, 2)
  basePriceUyu     Decimal  @map("base_price_uyu") @db.Decimal(10, 2)
  status           String   @default("available") @db.VarChar(20)

  product  CatalogProduct @relation(fields: [catalogProductId], references: [id])
  batch    Batch          @relation(fields: [batchId], references: [id], onDelete: Cascade)
  shipment Shipment?      @relation(fields: [shipmentId], references: [id], onDelete: SetNull)
  sale     Sale?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([status])
  @@index([catalogProductId, status])
  @@index([shipmentId])
  @@map("inventory_items")
}

model Sale {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  inventoryItemId String  @unique @map("inventory_item_id") @db.Uuid
  userId          String  @map("user_id") @db.Uuid
  loggedBy        User    @relation("SaleLogger", fields: [userId], references: [id])

  collectedByUserId String? @map("collected_by_user_id") @db.Uuid
  collectedByUser   User?   @relation("SaleCollector", fields: [collectedByUserId], references: [id])

  price       Decimal  @db.Decimal(10, 2)
  date        DateTime @default(now())
  method      String?  @db.VarChar(150)
  description String?  @db.Text

  item InventoryItem @relation(fields: [inventoryItemId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("sales")
}

model Expense {
  id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title    String   @db.VarChar(200)
  amount   Decimal  @db.Decimal(10, 2)
  currency String   @db.VarChar(5)
  date     DateTime @default(now()) @db.Date

  paidByUserId String @map("paid_by_user_id") @db.Uuid
  paidByUser   User   @relation("ExpensePayer", fields: [paidByUserId], references: [id])

  userId   String? @map("user_id") @db.Uuid
  loggedBy User?   @relation("ExpenseLogger", fields: [userId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("expenses")
}

model Conversion {
  id   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date DateTime @db.Date

  fromUserId String @map("from_user_id") @db.Uuid
  fromUser   User   @relation("ConversionSender", fields: [fromUserId], references: [id])

  fromCur String @map("from_cur") @db.VarChar(5)

  toUserId String @map("to_user_id") @db.Uuid
  toUser   User   @relation("ConversionReceiver", fields: [toUserId], references: [id])

  toCur      String  @map("to_cur") @db.VarChar(5)
  fromAmount Decimal @map("from_amount") @db.Decimal(12, 2)
  rate       Decimal @db.Decimal(10, 4)
  toAmount   Decimal @map("to_amount") @db.Decimal(12, 2)

  userId   String? @map("user_id") @db.Uuid
  loggedBy User?   @relation("ConversionLogger", fields: [userId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("conversions")
}

model Adjustment {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation("AdjustmentUser", fields: [userId], references: [id])
  amountUyu Decimal  @default(0) @map("amount_uyu") @db.Decimal(12, 2)
  amountUsd Decimal  @default(0) @map("amount_usd") @db.Decimal(12, 2)
  date      DateTime @db.Date
  note      String?  @db.VarChar(200)

  loggedByUserId String? @map("logged_by_user_id") @db.Uuid
  loggedBy       User?   @relation("AdjustmentLogger", fields: [loggedByUserId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("adjustments")
}
