datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            Int     @id @default(autoincrement())
  name          String  @db.VarChar(100)
  lastName      String  @map("last_name") @db.VarChar(100)
  email         String  @unique @db.VarChar(100)
  passwordHash  String  @map("password_hash") @db.VarChar(255)
  sales         Sale[]

  @@map("users")
}

model Batch {
  id                Int             @id @default(autoincrement())
  purchaseDate      DateTime        @default(now()) @map("purchase_date") @db.Date
  arrivalDate       DateTime?       @map("arrival_date") @db.Date 
  totalPrice        Decimal         @default(0.00) @map("total_price") @db.Decimal(10, 2)
  quantity          Int
  trackingNumber    String?         @map("tracking_number") @db.VarChar(100)
  description       String?         @db.Text 
  shippingPriceUsd  Decimal?        @map("shipping_price_usd") @db.Decimal(10, 2) 
  shippingPriceUyu  Decimal?        @map("shipping_price_uyu") @db.Decimal(10, 2) 
  weight            Decimal?        @db.Decimal(10, 2) 
  items             InventoryItem[]

  @@map("batches")
}

model CatalogProduct {
  id          Int             @id @default(autoincrement())
  team        String          @db.VarChar(100)
  season      String          @db.VarChar(20)
  version     String?         @db.VarChar(50)
  color       String          @db.VarChar(50) 
  number      Int?            
  player      String?         @db.VarChar(100) 
  description String?         @db.Text
  items       InventoryItem[]

  @@map("catalog_products")
}

model InventoryItem {
  id               Int            @id @default(autoincrement())
  catalogProductId Int            @map("catalog_product_id")
  batchId          Int            @map("batch_id")
  size             String         @db.VarChar(10)
  basePriceUsd     Decimal        @map("base_price_usd") @db.Decimal(10, 2) 
  finalPriceUsd    Decimal?       @map("final_price_usd") @db.Decimal(10, 2) 
  finalPriceUyu    Decimal?       @map("final_price_uyu") @db.Decimal(10, 2) 
  status           String         @default("available") @db.VarChar(20)
  
  product          CatalogProduct @relation(fields: [catalogProductId], references: [id])
  batch            Batch          @relation(fields: [batchId], references: [id], onDelete: Cascade)
  sale             Sale?

  @@map("inventory_items")
}

model Sale {
  id              Int           @id @default(autoincrement())
  inventoryItemId Int           @unique @map("inventory_item_id")
  userId          Int           @map("user_id")
  price           Decimal       @db.Decimal(10, 2)
  date            DateTime      @default(now())
  method          String?       @db.VarChar(150)
  description     String?       @db.Text 

  item            InventoryItem @relation(fields: [inventoryItemId], references: [id])
  user            User          @relation(fields: [userId], references: [id])

  @@map("sales")
}